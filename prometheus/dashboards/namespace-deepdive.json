      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "minVizHeight": 10
      },
      "targets": [
        {
          "expr": "topk(20, 100 * max by(pod,container)(container_memory_working_set_bytes{namespace=\"$namespace\",container!=\"\"} / on(namespace,pod,container) group_left() kube_pod_container_resource_limits{namespace=\"$namespace\",resource=\"memory\"}))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "legendFormat": "",
